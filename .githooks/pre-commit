#!/bin/sh
# .githooks/pre-commit — gate local que aborta el commit si la coherencia se rompe.
#
# Activación (una sola vez por clon):
#   git config core.hooksPath .githooks
#
# Checks que ejecuta:
#   1. scripts/check-coherence.sh       (siempre)
#   2. lychee --offline (todos los .md) (si lychee está instalado, opcional)
#
# (Desde v0.4.0 no hay plantilla-astro/ en el repo. Cada cliente bootstrapea
#  el proyecto Astro desde los snippets de la doctrina. El build se valida
#  en la ejecución de cada cliente, no en el repo del sistema.)

set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

printf '\n→ pre-commit: coherence\n'
sh scripts/check-coherence.sh

if command -v lychee >/dev/null 2>&1; then
  printf '\n→ pre-commit: lychee (links)\n'
  lychee --offline --no-progress --root-dir "$ROOT" './**/*.md' >/dev/null
  printf '  ok    sin enlaces rotos\n'
else
  printf '\n→ pre-commit: lychee no instalado — skip (CI lo verificará)\n'
fi

printf '\npre-commit OK\n\n'
