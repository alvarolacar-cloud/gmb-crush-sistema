---
import type { FAQ } from "@lib/types";

interface Props {
  title?: string;
  faqs: FAQ[];
}

const { title = "Preguntas frecuentes", faqs } = Astro.props;
---

{faqs && faqs.length > 0 && (
  <section class="faq">
    <h2 class="faq__heading">{title}</h2>
    <div class="faq__list">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__question">{f.q}</summary>
          <p class="faq__answer">{f.a}</p>
        </details>
      ))}
    </div>
  </section>
)}
