---
import { getTrustSignals } from "@lib/cluster";

interface Props {
  title?: string;
}

const { title = "Por qué elegirnos" } = Astro.props;
const trustSignals = getTrustSignals();
---

<section class="trust-block">
  <h2 class="trust-block__heading">{title}</h2>

  <div class="trust-block__list">
    {trustSignals.map((signal) => (
      <div class="trust-card">
        <p class="trust-card__label">{signal}</p>
      </div>
    ))}
  </div>
</section>
