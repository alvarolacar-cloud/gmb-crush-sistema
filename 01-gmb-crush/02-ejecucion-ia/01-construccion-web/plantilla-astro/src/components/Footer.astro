---
import {
  getBusinessName,
  getNAP,
  getServices,
  getMainCity,
  getMainCitySlug,
  getPrimaryCategorySlug,
  getLCAs,
  phoneHref,
} from "@lib/cluster";

const businessName = getBusinessName();
const nap = getNAP();
const services = getServices();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const primaryCatSlug = getPrimaryCategorySlug();
const lcas = getLCAs();

const allLcas = [...lcas.direct, ...lcas.candidate.slice(0, 4)];
const coverageText = allLcas.length > 0
  ? `Trabajamos en todo ${mainCity}: ${allLcas.join(", ")}${lcas.candidate.length > 4 ? " y más" : ""}.`
  : `Trabajamos en todo ${mainCity}.`;
---

<footer class="site-footer">
  <div class="site-footer__container">

    <div class="site-footer__column">
      <h3 class="site-footer__heading">{businessName}</h3>
      <address class="site-footer__address">
        {nap.street}<br />
        {nap.zip} {nap.city}<br />
        {nap.country}
      </address>
      <a href={phoneHref(nap.phone)} class="site-footer__phone">{nap.phone}</a>
      <a href={`mailto:${nap.email}`} class="site-footer__email">{nap.email}</a>
    </div>

    <div class="site-footer__column">
      <h4 class="site-footer__heading">Servicios</h4>
      <ul class="site-footer__list">
        {services.map((s) => (
          <li class="site-footer__list-item">
            <a
              href={`/${primaryCatSlug}/${mainCitySlug}/${s.slug}/`}
              class="site-footer__link"
            >
              {s.name}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="site-footer__column">
      <h4 class="site-footer__heading">Cobertura</h4>
      <p class="site-footer__nap">{coverageText}</p>
    </div>

    <div class="site-footer__column">
      <h4 class="site-footer__heading">Más</h4>
      <ul class="site-footer__list">
        <li class="site-footer__list-item">
          <a href="/contacto/" class="site-footer__link">Contacto</a>
        </li>
        <li class="site-footer__list-item">
          <a href="/aviso-legal/" class="site-footer__link">Aviso legal</a>
        </li>
        <li class="site-footer__list-item">
          <a href="/privacidad/" class="site-footer__link">Privacidad</a>
        </li>
      </ul>
    </div>

  </div>

  <p class="site-footer__copy">
    © {new Date().getFullYear()} {businessName}. Todos los derechos reservados.
  </p>
</footer>
