---
interface Props {
  h1: string;
  subtitle: string;
  trustItem?: string;
  ctaPrimary: string;
  ctaPrimaryHref: string;
  ctaSecondary?: string;
  ctaSecondaryHref?: string;
  /** URL de imagen CDN (output 16.7). Si existe → .hero--with-image. Si no → .hero--solid. */
  heroImage?: string;
}

const {
  h1,
  subtitle,
  trustItem,
  ctaPrimary,
  ctaPrimaryHref,
  ctaSecondary,
  ctaSecondaryHref,
  heroImage,
} = Astro.props;

const heroClass = heroImage ? "hero hero--with-image" : "hero hero--solid";
---

<section class={heroClass}>
  {heroImage && (
    <>
      <img class="hero__image" src={heroImage} alt="" aria-hidden="true" loading="eager" decoding="async" />
      <div class="hero__overlay"></div>
    </>
  )}

  <div class="hero__content">
    <h1 class="hero__title">{h1}</h1>
    <p class="hero__subtitle">{subtitle}</p>
    {trustItem && <p class="hero__trust">{trustItem}</p>}

    <div class="hero__actions">
      <a href={ctaPrimaryHref} class="hero__cta--primary">{ctaPrimary}</a>
      {ctaSecondary && ctaSecondaryHref && (
        <a href={ctaSecondaryHref} class="hero__cta--secondary">{ctaSecondary}</a>
      )}
    </div>
  </div>
</section>
