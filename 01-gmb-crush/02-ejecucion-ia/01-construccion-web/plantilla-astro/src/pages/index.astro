---
/**
 * Homepage stub.
 *
 * Esta página existe como placeholder mínimo para que `pnpm build` funcione sin
 * cliente. CADA CLIENTE la sobreescribe en su carpeta `ejecuciones-webs/[slug]/web/src/pages/index.astro`
 * con HTML libre que refleje fielmente la web de referencia (output de Fase 4).
 *
 * Patrón típico:
 *   import BaseLayout from "@layouts/BaseLayout.astro";
 *   import { organization, localBusiness, ... } from "@lib/schema-helpers";
 *   import { getValue, getDomain } from "@lib/cluster";
 *
 *   const services = getValue<...>("1.9");
 *   const schemas = [organization({...}), localBusiness({...})];
 *
 *   <BaseLayout title="..." description="..." schema={schemas} bodyClass="page--home">
 *     ... HTML libre fiel a la referencia ...
 *   </BaseLayout>
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import { getBusinessName, getDomain } from "@lib/cluster";

const name = getBusinessName();
const domain = getDomain();
---

<BaseLayout
  title={`${name} — sitio en construcción`}
  description={`${name}. Sitio en construcción.`}
  bodyClass="page--placeholder"
>
  <main style="font-family: system-ui, sans-serif; max-width: 640px; margin: 64px auto; padding: 0 24px;">
    <h1 style="font-size: 32px; margin-bottom: 16px;">{name}</h1>
    <p style="color: #555;">
      Sitio en construcción. Esta es la página por defecto de la plantilla del sistema.
      Para verla con contenido real, cada cliente sobreescribe <code>src/pages/index.astro</code>
      en su carpeta de ejecución con HTML libre, usando <code>BaseLayout</code> y los helpers de
      <code>schema-helpers</code> / <code>cluster</code>.
    </p>
    <p style="color: #555;">
      Dominio configurado: <a href={domain}>{domain}</a>
    </p>
  </main>
</BaseLayout>
