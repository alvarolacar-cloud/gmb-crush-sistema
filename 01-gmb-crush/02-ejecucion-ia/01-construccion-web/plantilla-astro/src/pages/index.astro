---
/**
 * Homepage (HP) — `/`
 * Doctrina: Root Entity Anchor. Schema Organization + WebSite (NO LocalBusiness, NO FAQPage en schema).
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import ServicesGrid from "@components/ServicesGrid.astro";
import TrustBlock from "@components/TrustBlock.astro";
import Faqs from "@components/Faqs.astro";
import {
  getBusinessName,
  getNAP,
  getMainCity,
  getMainCitySlug,
  getLCAs,
  getTrustSignals,
  getPreferredCTA,
  getPrimaryCategory,
  phoneHref,
  getFaqsHomepage,
  getImages,
} from "@lib/cluster";
import { buildHomepageSchemas } from "@lib/schemas";

const businessName = getBusinessName();
const nap = getNAP();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const lcas = getLCAs();
const trustSignals = getTrustSignals();
const cta = getPreferredCTA();
const primaryCategory = getPrimaryCategory();
const faqs = getFaqsHomepage();
const images = getImages();

const title = `${businessName} · ${primaryCategory} en ${mainCity}`;
const description = `${primaryCategory} en ${mainCity}${
  lcas.direct.length ? `: ${lcas.direct.join(", ")}` : ""
}.${trustSignals[0] ? ` ${trustSignals[0]}.` : ""}`;

const schema = buildHomepageSchemas();

// H1 doctrinal: Primary Category + Main City. NO concatena Pre.2 (que ya puede incluir ciudad).
const heroTitle = `${primaryCategory} en ${mainCity}`;
const heroSubtitle = `Especialistas en ${primaryCategory.toLowerCase()}${
  lcas.direct.length
    ? ` con cobertura en zonas como ${lcas.direct.join(", ")}`
    : ` en ${mainCity}`
}.`;
---

<BaseLayout title={title} description={description} schema={schema} pageType="home">
  <Hero
    h1={heroTitle}
    subtitle={heroSubtitle}
    trustItem={trustSignals[0]}
    ctaPrimary={cta}
    ctaPrimaryHref="/contacto/"
    ctaSecondary={`Llamar ${nap.phone}`}
    ctaSecondaryHref={phoneHref(nap.phone)}
    heroImage={images.hero_homepage}
  />

  <ServicesGrid />

  <TrustBlock />

  <Faqs faqs={faqs} />

  <section class="cta-section">
    <h2 class="cta-section__title">¿Empezamos?</h2>
    <p class="cta-section__description">
      Presupuesto sin compromiso en 24h. Trabajamos en todo {mainCity}.
    </p>
    <a href="/contacto/" class="cta-section__button">{cta}</a>
  </section>

  <section class="content">
    <p class="content__paragraph">
      Ver el <a href={`/${mainCitySlug}/`} class="content__link">índice de servicios en {mainCity}</a>.
    </p>
  </section>
</BaseLayout>
