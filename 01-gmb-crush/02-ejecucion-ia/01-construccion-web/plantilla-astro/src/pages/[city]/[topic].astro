---
/**
 * GeoArticle (GA) — `/[city]/[topic]/`
 * Doctrina: booster semántico, NO landing. CTA suave hacia LBS padre.
 * Schema: Article + FAQPage + BreadcrumbList + Speakable.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Faqs from "@components/Faqs.astro";
import {
  getDomain,
  getMainCity,
  getMainCitySlug,
  getPrimaryCategorySlug,
  getServices,
  getGeoArticleTopics,
  getFaqsGeoArticle,
  getPreferredCTA,
} from "@lib/cluster";
import { buildGeoArticleSchemas } from "@lib/schemas";
import type { GeoArticleTopic } from "@lib/types";

export async function getStaticPaths() {
  const topics = getGeoArticleTopics();
  const mainCitySlug = getMainCitySlug();
  return topics.map((topic) => ({
    params: { city: mainCitySlug, topic: topic.topic_slug },
    props: { topic },
  }));
}

interface Props {
  topic: GeoArticleTopic;
}

const { topic } = Astro.props;
const domain = getDomain();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const primaryCatSlug = getPrimaryCategorySlug();
const services = getServices();
const faqs = getFaqsGeoArticle();
const cta = getPreferredCTA();

const parentService = services.find((s) => s.slug === topic.service_slug);
const lbsUrl = parentService
  ? `/${primaryCatSlug}/${mainCitySlug}/${parentService.slug}/`
  : `/${mainCitySlug}/`;

const url = `${domain}${mainCitySlug}/${topic.topic_slug}/`;
const title = `${topic.title}`;
const description = `${topic.title}. Guía práctica con respuesta directa, factores y casos en ${mainCity}.`;

const schema = buildGeoArticleSchemas({
  title: topic.title,
  url,
  faqs,
  breadcrumbs: [
    { name: "Inicio", url: domain },
    { name: mainCity, url: `${domain}${mainCitySlug}/` },
    { name: topic.title },
  ],
});
---

<BaseLayout title={title} description={description} schema={schema} pageType="geoarticle">
  <article class="content">
    <section class="hero hero--solid">
      <div class="hero__content">
        <h1 class="hero__title">{topic.title}</h1>
      </div>
    </section>

    <p class="content__quick-answer">
      <strong class="content__strong">Respuesta breve:</strong> esta es una guía sobre {topic.title.toLowerCase()} en {mainCity}.
      Aquí encuentras los factores, plazos y referencias prácticas.
    </p>

    <h2 class="content__heading">Desglose</h2>
    <p class="content__paragraph">
      [Contenido pendiente — Fase 4 (Redacción) escribirá aquí ≥1000 palabras de respuesta detallada con factores, casos y referencias locales a {mainCity}.]
    </p>

    <h2 class="content__heading">Factores que influyen</h2>
    <p class="content__paragraph">[Pendiente.]</p>

    <h2 class="content__heading">Casos en {mainCity}</h2>
    <p class="content__paragraph">[Pendiente.]</p>

    {parentService && (
      <p class="content__bridge">
        ¿Quieres presupuesto para <strong class="content__strong">{parentService.name}</strong> en {mainCity}?
        <a href={lbsUrl} class="content__link">Ver {parentService.name} en {mainCity} →</a>
      </p>
    )}

    <Faqs faqs={faqs} />

    <section class="cta-section">
      <p class="cta-section__description">
        Ver el <a href={`/${mainCitySlug}/`} class="content__link">índice de servicios en {mainCity}</a>.
      </p>
      <a href="/contacto/" class="cta-section__button">{cta}</a>
    </section>
  </article>
</BaseLayout>
