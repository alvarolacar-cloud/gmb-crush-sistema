---
/**
 * GeoHub — `/[city]/`
 * Doctrina: contenedor de ciudad. Schema CollectionPage + BreadcrumbList.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import TrustBlock from "@components/TrustBlock.astro";
import Faqs from "@components/Faqs.astro";
import {
  getDomain,
  getBusinessName,
  getMainCity,
  getMainCitySlug,
  getPrimaryCategorySlug,
  getServices,
  getLCAs,
  getGeoArticleTopics,
  getAdditionalCategoriesWithPage,
  getFaqsGeoHub,
  getPreferredCTA,
} from "@lib/cluster";
import { buildGeoHubSchemas } from "@lib/schemas";

export async function getStaticPaths() {
  return [{ params: { city: getMainCitySlug() } }];
}

const businessName = getBusinessName();
const domain = getDomain();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const primaryCatSlug = getPrimaryCategorySlug();
const services = getServices();
const lcas = getLCAs();
const topics = getGeoArticleTopics();
const additionals = getAdditionalCategoriesWithPage();
const faqs = getFaqsGeoHub();
const cta = getPreferredCTA();

const url = `${domain}${mainCitySlug}/`;
const title = `Servicios en ${mainCity} · ${businessName}`;
const allCoverage = [...lcas.direct, ...lcas.candidate.slice(0, 4)];
const description = `Cobertura completa en ${mainCity}: ${services.map((s) => s.name).join(", ")}.${
  allCoverage.length ? ` Zonas: ${allCoverage.join(", ")}.` : ""
}`;

const schema = buildGeoHubSchemas({
  cityName: mainCity,
  url,
  breadcrumbs: [
    { name: "Inicio", url: domain },
    { name: mainCity },
  ],
});
---

<BaseLayout title={title} description={description} schema={schema} pageType="geohub">
  <section class="hero hero--solid">
    <div class="hero__content">
      <h1 class="hero__title">Servicios en {mainCity}</h1>
      <p class="hero__subtitle">
        Cobertura completa en {mainCity}{allCoverage.length ? `: ${allCoverage.join(", ")}` : ""}.
      </p>
      <div class="hero__actions">
        <a href="/contacto/" class="hero__cta--primary">{cta}</a>
      </div>
    </div>
  </section>

  <section class="services-grid">
    <h2 class="services-grid__heading">Nuestros servicios en {mainCity}</h2>
    <div class="services-grid__list">
      {services.map((s) => (
        <a href={`/${primaryCatSlug}/${mainCitySlug}/${s.slug}/`} class="service-card">
          <h3 class="service-card__title">{s.name}</h3>
          <p class="service-card__description">En {mainCity}, presupuesto sin compromiso.</p>
        </a>
      ))}
    </div>
  </section>

  {additionals.length > 0 && (
    <section class="services-grid">
      <h2 class="services-grid__heading">Otros servicios</h2>
      <div class="services-grid__list">
        {additionals.map((ac) => (
          <a href={`/${primaryCatSlug}/${mainCitySlug}/${ac.page_slug}/`} class="service-card">
            <h3 class="service-card__title">{ac.category}</h3>
          </a>
        ))}
      </div>
    </section>
  )}

  {topics.length > 0 && (
    <section class="guides">
      <h2 class="guides__heading">Guías sobre {mainCity}</h2>
      <div class="guides__list">
        {topics.slice(0, 12).map((t) => (
          <a href={`/${mainCitySlug}/${t.topic_slug}/`} class="guides__item">{t.title}</a>
        ))}
      </div>
    </section>
  )}

  {allCoverage.length > 0 && (
    <section class="lcas">
      <h2 class="lcas__heading">Cobertura</h2>
      <p class="lcas__intro">Trabajamos en {mainCity} con foco en estas zonas:</p>
      <ul class="lcas__list">
        {allCoverage.map((zona) => (
          <li class="lcas__item">{zona}</li>
        ))}
      </ul>
    </section>
  )}

  <TrustBlock />

  <Faqs faqs={faqs} title={`Preguntas frecuentes — ${mainCity}`} />
</BaseLayout>
