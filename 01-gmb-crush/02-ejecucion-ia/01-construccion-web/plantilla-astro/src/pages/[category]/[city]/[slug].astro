---
/**
 * LBS y AC comparten URL pattern doctrinal: `/[category]/[city]/[slug]/`.
 *   - Si el slug coincide con un service → LBS (LocalBusiness + FAQPage + BreadcrumbList)
 *   - Si coincide con additional category → AC (Service + BreadcrumbList)
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import TrustBlock from "@components/TrustBlock.astro";
import Faqs from "@components/Faqs.astro";
import {
  getDomain,
  getBusinessName,
  getNAP,
  getMainCity,
  getMainCitySlug,
  getPrimaryCategorySlug,
  getPrimaryCategory,
  getServices,
  getLCAs,
  getTrustSignals,
  getGeoArticleTopics,
  getAdditionalCategoriesWithPage,
  getFaqsLBS,
  getFaqsAdditionalCategory,
  getPreferredCTA,
  phoneHref,
} from "@lib/cluster";
import {
  buildLBSSchemas,
  buildAdditionalCategorySchemas,
} from "@lib/schemas";
import type { Service, AdditionalCategory } from "@lib/types";

type LBSEntry = { kind: "LBS"; service: Service };
type ACEntry = { kind: "AC"; ac: AdditionalCategory };

export async function getStaticPaths() {
  const services = getServices();
  const additionals = getAdditionalCategoriesWithPage();
  const categorySlug = getPrimaryCategorySlug();
  const mainCitySlug = getMainCitySlug();

  const lbsRoutes = services.map((service) => ({
    params: { category: categorySlug, city: mainCitySlug, slug: service.slug },
    props: { kind: "LBS" as const, service } satisfies LBSEntry,
  }));

  const acRoutes = additionals
    .filter((ac) => ac.page_slug)
    .map((ac) => ({
      params: { category: categorySlug, city: mainCitySlug, slug: ac.page_slug! },
      props: { kind: "AC" as const, ac } satisfies ACEntry,
    }));

  return [...lbsRoutes, ...acRoutes];
}

type Props = LBSEntry | ACEntry;
const props = Astro.props as Props;

const businessName = getBusinessName();
const domain = getDomain();
const nap = getNAP();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const primaryCategory = getPrimaryCategory();
const primaryCatSlug = getPrimaryCategorySlug();
const trustSignals = getTrustSignals();
const cta = getPreferredCTA();
const lcas = getLCAs();

let title: string;
let description: string;
let schema: Record<string, unknown>[];
let h1: string;
let entityName: string;
let url: string;
let faqs;
const pageType: "lbs" | "additional-category" = props.kind === "LBS" ? "lbs" : "additional-category";

if (props.kind === "LBS") {
  const { service } = props;
  url = `${domain}${primaryCatSlug}/${mainCitySlug}/${service.slug}/`;
  faqs = getFaqsLBS();
  entityName = service.name;
  h1 = `${service.name} en ${mainCity}`;
  title = `${service.name} en ${mainCity} · ${businessName}`;
  description = `${service.name} en ${mainCity}: ${trustSignals[0] ?? ""}. Cobertura ${lcas.direct.join(", ")}.`;
  schema = buildLBSSchemas({
    serviceName: service.name,
    url,
    faqs,
    breadcrumbs: [
      { name: "Inicio", url: domain },
      { name: primaryCategory, url: `${domain}${primaryCatSlug}/` },
      { name: mainCity, url: `${domain}${mainCitySlug}/` },
      { name: service.name },
    ],
  });
} else {
  const { ac } = props;
  url = `${domain}${primaryCatSlug}/${mainCitySlug}/${ac.page_slug}/`;
  faqs = getFaqsAdditionalCategory();
  entityName = ac.category;
  h1 = `${ac.category} en ${mainCity}`;
  title = `${ac.category} en ${mainCity} · ${businessName}`;
  description = `${ac.category} en ${mainCity}. Servicio especializado.`;
  schema = buildAdditionalCategorySchemas({
    categoryName: ac.category,
    url,
    breadcrumbs: [
      { name: "Inicio", url: domain },
      { name: primaryCategory, url: `${domain}${primaryCatSlug}/` },
      { name: mainCity, url: `${domain}${mainCitySlug}/` },
      { name: ac.category },
    ],
  });
}

const allLcas = [...lcas.direct, ...lcas.candidate];
const childTopics =
  props.kind === "LBS"
    ? getGeoArticleTopics().filter((t) => t.service_slug === props.service.slug)
    : [];
const ghUrl = `/${mainCitySlug}/`;
const soUrl = props.kind === "LBS" ? `/${primaryCatSlug}/${props.service.slug}/` : null;
---

<BaseLayout title={title} description={description} schema={schema} pageType={pageType}>
  <Hero
    h1={h1}
    subtitle={`Especialistas en ${entityName.toLowerCase()} con cobertura en todo ${mainCity}.`}
    trustItem={trustSignals[0]}
    ctaPrimary={cta}
    ctaPrimaryHref="/contacto/"
    ctaSecondary={`Llamar ${nap.phone}`}
    ctaSecondaryHref={phoneHref(nap.phone)}
  />

  {allLcas.length > 0 && (
    <section class="lcas">
      <h2 class="lcas__heading">Cobertura en {mainCity}</h2>
      <p class="lcas__intro">Trabajamos {entityName.toLowerCase()} en todo <strong class="content__strong">{mainCity}</strong>, con foco en:</p>
      <ul class="lcas__list">
        {allLcas.map((zona) => (
          <li class="lcas__item">{zona}</li>
        ))}
      </ul>
    </section>
  )}

  <TrustBlock />

  <Faqs faqs={faqs} title={`FAQ — ${entityName} en ${mainCity}`} />

  {childTopics.length > 0 && (
    <section class="guides">
      <h2 class="guides__heading">Más sobre {entityName.toLowerCase()}</h2>
      <div class="guides__list">
        {childTopics.map((t) => (
          <a href={`/${mainCitySlug}/${t.topic_slug}/`} class="guides__item">{t.title}</a>
        ))}
      </div>
    </section>
  )}

  <section class="cta-section">
    <p class="cta-section__description">
      {soUrl && (
        <>¿Servicio en general? <a href={soUrl} class="content__link">{entityName}</a>. </>
      )}
      Ver el <a href={ghUrl} class="content__link">índice de servicios en {mainCity}</a>.
    </p>
    <a href="/contacto/" class="cta-section__button">{cta}</a>
  </section>
</BaseLayout>
