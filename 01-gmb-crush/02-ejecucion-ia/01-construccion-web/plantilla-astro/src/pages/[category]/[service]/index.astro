---
/**
 * Service Overview (SO) — `/[category]/[service]/`
 * Doctrina: explica el servicio SIN ciudad. Empuja a LBS.
 * Schema: Service + WebPage + BreadcrumbList.
 */
import BaseLayout from "@layouts/BaseLayout.astro";
import Faqs from "@components/Faqs.astro";
import {
  getDomain,
  getBusinessName,
  getServices,
  getMainCity,
  getMainCitySlug,
  getPrimaryCategorySlug,
  getPrimaryCategory,
  getFaqsServiceOverview,
  getPreferredCTA,
} from "@lib/cluster";
import { buildServiceOverviewSchemas } from "@lib/schemas";
import type { Service } from "@lib/types";

export async function getStaticPaths() {
  const services = getServices();
  const categorySlug = getPrimaryCategorySlug();
  return services.map((service) => ({
    params: { category: categorySlug, service: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;
const businessName = getBusinessName();
const domain = getDomain();
const mainCity = getMainCity();
const mainCitySlug = getMainCitySlug();
const primaryCatSlug = getPrimaryCategorySlug();
const primaryCategory = getPrimaryCategory();
const faqs = getFaqsServiceOverview();
const cta = getPreferredCTA();

const url = `${domain}${primaryCatSlug}/${service.slug}/`;
const lbsUrl = `/${primaryCatSlug}/${mainCitySlug}/${service.slug}/`;

const title = `${service.name} · ${businessName}`;
const description = `${service.name}: cómo lo hacemos, qué incluye, plazos y precios orientativos.`;

const schema = buildServiceOverviewSchemas({
  serviceName: service.name,
  primaryCategory,
  url,
  breadcrumbs: [
    { name: "Inicio", url: domain },
    { name: primaryCategory, url: `${domain}${primaryCatSlug}/` },
    { name: service.name },
  ],
});
---

<BaseLayout title={title} description={description} schema={schema} pageType="service-overview">
  <section class="hero hero--solid">
    <div class="hero__content">
      <h1 class="hero__title">{service.name}</h1>
      <p class="hero__subtitle">
        Aquí explicamos en qué consiste {service.name.toLowerCase()}, cómo trabajamos y qué incluye.
      </p>
      <div class="hero__actions">
        <a href={lbsUrl} class="hero__cta--primary">
          Ver {service.name.toLowerCase()} en {mainCity}
        </a>
      </div>
    </div>
  </section>

  <section class="content">
    <h2 class="content__heading">Cómo trabajamos</h2>
    <ol class="content__list">
      <li class="content__list-item"><strong class="content__strong">1. Visita gratuita.</strong> Tomamos medidas y entendemos tus necesidades.</li>
      <li class="content__list-item"><strong class="content__strong">2. Presupuesto cerrado.</strong> Por escrito, sin sorpresas.</li>
      <li class="content__list-item"><strong class="content__strong">3. Ejecución profesional.</strong> Técnicos cualificados con experiencia.</li>
      <li class="content__list-item"><strong class="content__strong">4. Garantía.</strong> Sobre todos los trabajos.</li>
    </ol>

    <h2 class="content__heading">Versión local</h2>
    <p class="content__paragraph">
      Si estás en {mainCity}, consulta la página específica con cobertura por barrios:
    </p>
    <p class="content__bridge">
      <a href={lbsUrl} class="content__link">{service.name} en {mainCity} →</a>
    </p>
  </section>

  <Faqs faqs={faqs} title={`FAQ — ${service.name}`} />

  <section class="cta-section">
    <h2 class="cta-section__title">Solicita presupuesto</h2>
    <a href="/contacto/" class="cta-section__button">{cta}</a>
  </section>
</BaseLayout>
