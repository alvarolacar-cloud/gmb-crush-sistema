---
import BaseLayout from "@layouts/BaseLayout.astro";
import {
  getBusinessName,
  getDomain,
  getNAP,
  getMainCity,
  getServices,
  buildPostalAddress,
  phoneHref,
} from "@lib/cluster";

const businessName = getBusinessName();
const domain = getDomain();
const nap = getNAP();
const mainCity = getMainCity();
const services = getServices();

const title = `Contacto · ${businessName}`;
const description = `Contacta con ${businessName} en ${mainCity}. Presupuesto sin compromiso en 24h.`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "ContactPage",
    name: title,
    url: `${domain}contacto/`,
    mainEntity: {
      "@type": "Organization",
      name: businessName,
      telephone: nap.phone,
      email: nap.email,
      address: buildPostalAddress(nap),
    },
  },
];
---

<BaseLayout title={title} description={description} schema={schema} pageType="contact">
  <section class="content">
    <h1 class="content__heading">Contacto</h1>
    <p class="content__paragraph">
      ¿Quieres presupuesto? Llámanos, escríbenos o visítanos en {nap.city}. Respuesta en 24h.
    </p>

    <div class="contact-info">
      <div class="contact-info__block">
        <h2 class="content__heading">Teléfono</h2>
        <a href={phoneHref(nap.phone)} class="contact-info__phone">{nap.phone}</a>
      </div>
      <div class="contact-info__block">
        <h2 class="content__heading">Email</h2>
        <a href={`mailto:${nap.email}`} class="contact-info__email">{nap.email}</a>
      </div>
      <div class="contact-info__block">
        <h2 class="content__heading">Dirección</h2>
        <address class="contact-info__address">
          {nap.street}<br />
          {nap.zip} {nap.city}<br />
          {nap.country}
        </address>
      </div>
    </div>

    <form action={`mailto:${nap.email}`} method="post" enctype="text/plain" class="contact-form">
      <h2 class="contact-form__heading">Solicitar presupuesto</h2>
      <div class="contact-form__field">
        <label for="nombre" class="contact-form__label">Nombre</label>
        <input id="nombre" name="nombre" type="text" required class="contact-form__input" />
      </div>
      <div class="contact-form__field">
        <label for="phone" class="contact-form__label">Teléfono</label>
        <input id="phone" name="phone" type="tel" required class="contact-form__input" />
      </div>
      <div class="contact-form__field">
        <label for="servicio" class="contact-form__label">Servicio</label>
        <select id="servicio" name="servicio" class="contact-form__select">
          {services.map((s) => (
            <option value={s.slug}>{s.name}</option>
          ))}
        </select>
      </div>
      <div class="contact-form__field">
        <label for="mensaje" class="contact-form__label">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="4" class="contact-form__textarea"></textarea>
      </div>
      <button type="submit" class="contact-form__submit">Enviar</button>
    </form>
  </section>
</BaseLayout>
